# Vespera World - Ops Homebase Environment Variables
# Copy to .env and fill values. NEVER commit .env.

TZ=UTC

# n8n
N8N_HOST=n8n.yourdomain.com
N8N_USER=admin
N8N_PASSWORD=SET_YOUR_PASSWORD
N8N_ENCRYPTION_KEY=SET_32_CHAR_RANDOM_STRING

# Budibase
BUDIBASE_JWT_SECRET=SET_SECRET
BUDIBASE_MINIO_KEY=SET_MINIO_KEY
BUDIBASE_MINIO_SECRET=SET_MINIO_SECRET
BUDIBASE_REDIS_PASSWORD=SET_REDIS_PASS
BUDIBASE_INTERNAL_KEY=SET_INTERNAL_KEY

# code-server
CODE_SERVER_PASSWORD=SET_PASSWORD

# Appwrite
APPWRITE_DOMAIN=appwrite.yourdomain.com
APPWRITE_WHITELIST_EMAILS=your@email.com
APPWRITE_WHITELIST_IPS=
APPWRITE_EMAIL_NAME=Vespera
APPWRITE_EMAIL_ADDRESS=noreply@yourdomain.com
APPWRITE_EXECUTOR_SECRET=SET_SECRET

# MariaDB
MARIADB_ROOT_PASSWORD=SET_ROOT_PASSWORD

# Redis
REDIS_PASSWORD=SET_REDIS_PASSWORD

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=none
SMTP_USER=
SMTP_PASSWORD=SET_SMTP_PASSWORD

# Hermes
HERMES_API_URL=http://hermes:8642/v1/chat/completions
HERMES_API_KEY=SET_HERMES_KEY
